<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Northstar Workroom</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="site-header">
      <div>
        <a class="brand" href="/">Northstar Workroom</a>
        <p class="banner">Intentionally insecure AI-generated demo. Local use only. Never deploy.</p>
      </div>
      <nav>
        <% if (currentUser) { %>
          <a href="/dashboard">Dashboard</a>
          <a href="/search">Search</a>
          <a href="/reports">Exports</a>
          <a href="/profile">Profile</a>
          <% if (currentUser.role === "admin" || canManageUsers) { %>
            <a href="/admin">Admin</a>
          <% } %>
          <form action="/logout" method="post" class="inline-form">
            <button type="submit">Logout</button>
          </form>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
        <% } %>
      </nav>
    </header>
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>
    <main class="page-shell">

