<%- include("../partials/header", { title }) %>
<section class="split">
  <div class="card">
    <h1>Admin Dashboard</h1>
    <div class="stats">
      <div><strong><%= stats.users %></strong><span>Users</span></div>
      <div><strong><%= stats.workspaces %></strong><span>Workspaces</span></div>
      <div><strong><%= stats.projects %></strong><span>Projects</span></div>
      <div><strong><%= stats.jobs %></strong><span>Export Jobs</span></div>
    </div>

    <h2>Users</h2>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Email</th>
          <th>Name</th>
          <th>Role</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.email %></td>
            <td><%= user.full_name %></td>
            <td><%= user.role %></td>
            <td>
              <form action="/admin/users/<%= user.id %>/role" method="post" class="inline-form">
                <select name="role">
                  <option value="user">user</option>
                  <option value="admin">admin</option>
                </select>
                <button type="submit">Update</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <aside class="card">
    <h2>Recent Audit Activity</h2>
    <ul>
      <% logs.forEach((log) => { %>
        <li><%= log.action %> by <%= log.actor_name || "system" %> on <%= log.target_type %>#<%= log.target_id %></li>
      <% }) %>
    </ul>
    <p><a href="/api/debug/session">Debug session payload</a></p>
  </aside>
</section>
<%- include("../partials/footer") %>

